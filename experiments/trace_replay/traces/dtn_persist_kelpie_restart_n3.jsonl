{"at_ms":0,"type":"metrics","note":"dtn-persist-kelpie-restart-n3"}

# 场景：在 Kelpie 重启之前入队 DTN bundle（且人为暂停派发），要求重启后仍能从 SQLite 恢复并最终交付。
#
# 这条 trace 主要覆盖：
# - DTN 队列状态在 Kelpie 重启后的持久化与一致性
# - inflight/queued bundle 的“至少一次”恢复语义（重启后可继续派发并完成交付）

# 暂停 DTN 派发，确保这些 bundle 不会在重启前被发送/ACK。
{"at_ms":200,"type":"dtn_policy","key":"max_inflight_per_target","value":"0","timeout_ms":6000}

# 入队多条可观测 payload（log: 前缀由 agent 转为 RuntimeLog 上报，run_regress.py 会在 Kelpie 日志中断言出现）。
{"at_ms":800,"type":"dtn_enqueue","target":"n3","payload":"log:dtn-persist-pre-restart-01","priority":"normal","ttl_seconds":600}
{"at_ms":900,"type":"dtn_enqueue","target":"n3","payload":"log:dtn-persist-pre-restart-02","priority":"normal","ttl_seconds":600}
{"at_ms":1000,"type":"dtn_enqueue","target":"n3","payload":"log:dtn-persist-pre-restart-03","priority":"normal","ttl_seconds":600}
{"at_ms":1100,"type":"dtn_enqueue","target":"n3","payload":"log:dtn-persist-pre-restart-04","priority":"normal","ttl_seconds":600}
{"at_ms":1200,"type":"dtn_enqueue","target":"n3","payload":"log:dtn-persist-pre-restart-05","priority":"normal","ttl_seconds":600}
{"at_ms":1300,"type":"dtn_enqueue","target":"n3","payload":"log:dtn-persist-pre-restart-06","priority":"normal","ttl_seconds":600}

# Kelpie 中途重启（复用相同 runDir SQLite；root 会自动重连）。
{"at_ms":12000,"type":"kelpie_restart","timeout_ms":60000}

# 等待拓扑/重连收敛：确认目标在线（更稳定，也能覆盖 wait_node_status 逻辑）。
{"at_ms":25000,"type":"wait_node_status","node":"n3","expect":"online","timeout_ms":60000}

# 恢复 DTN 派发，要求重启前入队的 bundle 全部能最终交付。
{"at_ms":27000,"type":"dtn_policy","key":"max_inflight_per_target","value":"8","timeout_ms":6000}

{"at_ms":75000,"type":"metrics","note":"checkpoint-75s"}

